# Formal SEE input evidence in RDF 1.2 TriG.
# The generated runner reads this TriG evidence directly.

:sqrt2Proc rdf:type :DyadicBisection .
:sqrt2Proc :maxN 20 .
:HGate rdf:type :SingleQubitGate .
:HGate :name "H" .
:HGate :usesScale :invSqrt2 .
:invSqrt2 rdf:type :PositiveRealApprox .
:invSqrt2 :definedAs "1/sqrt2" .
:sqrt2Proc :state (0 1 2) .

