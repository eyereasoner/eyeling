# Formal SEE input evidence in RDF 1.2 TriG.
# The generated runner reads this TriG evidence directly.

:Case :unstableMatrix :A_unstable .
:Case :stableMatrix :A_stable .
:Case :dampedMatrix :A_damped .
:Scale2 :k 2 .
:c_0_0 :re 0 .
:c_0_0 :im 0 .
:c_0_0 :pretty "(0,0)" .
:c_0_1 :re 0 .
:c_0_1 :im 1 .
:c_0_1 :pretty "(0,1)" .
:c_1_0 :re 1 .
:c_1_0 :im 0 .
:c_1_0 :pretty "(1,0)" .
:c_m1_0 :re -1 .
:c_m1_0 :im 0 .
:c_m1_0 :pretty "(-1,0)" .
:c_1_1 :re 1 .
:c_1_1 :im 1 .
:c_1_1 :pretty "(1,1)" .
:c_1_2 :re 1 .
:c_1_2 :im 2 .
:c_1_2 :pretty "(1,2)" .
:c_2_0 :re 2 .
:c_2_0 :im 0 .
:c_2_0 :pretty "(2,0)" .
:A_unstable :a11 :c_1_1 .
:A_unstable :a12 :c_0_0 .
:A_unstable :a21 :c_0_0 .
:A_unstable :a22 :c_2_0 .
:A_unstable :pretty "[[(1,1),(0,0)],[(0,0),(2,0)]]" .
:A_stable :a11 :c_1_0 .
:A_stable :a12 :c_0_0 .
:A_stable :a21 :c_0_0 .
:A_stable :a22 :c_m1_0 .
:A_stable :pretty "[[(1,0),(0,0)],[(0,0),(-1,0)]]" .
:A_damped :a11 :c_0_0 .
:A_damped :a12 :c_0_0 .
:A_damped :a21 :c_0_0 .
:A_damped :a22 :c_0_0 .
:A_damped :pretty "[[(0,0),(0,0)],[(0,0),(0,0)]]" .

