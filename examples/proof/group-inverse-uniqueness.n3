@prefix : <http://example.org/#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix pe: <https://eyereasoner.github.io/pe#> .

:result :sameInverse (:x :i :j) .
:result :sameInverse (:x :j :i) .

{ :result :sameInverse (:x :i :j) . } pe:why {
  { :result :sameInverse (:x :i :j) . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 167 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :i ],
      [ pe:var "z"; pe:value :j ];
    pe:uses
      { (:x :i :j) :sameInverse true . },
      { :i log:notEqualTo :j . }.

  { (:x :i :j) :sameInverse true . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 138 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :i ],
      [ pe:var "z"; pe:value :j ];
    pe:uses
      { :i :inverseOf :x . },
      { :j :inverseOf :x . },
      { (:i :j) :sameTerm true . }.

  { :i :inverseOf :x . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 158 ].

  { :j :inverseOf :x . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 159 ].

  { (:i :j) :sameTerm true . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 54 ];
    pe:binding
      [ pe:var "a"; pe:value :j ],
      [ pe:var "ab"; pe:value :e ],
      [ pe:var "b"; pe:value :x ],
      [ pe:var "bc"; pe:value :e ],
      [ pe:var "c"; pe:value :i ],
      [ pe:var "left"; pe:value :i ],
      [ pe:var "right"; pe:value :j ];
    pe:uses
      { (:j :x) :mul :e . },
      { (:e :i) :mul :i . },
      { (:x :i) :mul :e . },
      { (:j :e) :mul :j . }.

  { (:j :x) :mul :e . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 102 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :j ];
    pe:uses
      { :x :inG true . },
      { :j :inG true . },
      { :j :inverseOf :x . }.

  { :x :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 153 ].

  { :j :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 155 ].

  { (:e :i) :mul :i . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 78 ];
    pe:binding [ pe:var "a"; pe:value :i ];
    pe:uses { :i :inG true . }.

  { :i :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 154 ].

  { (:x :i) :mul :e . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 102 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :i ];
    pe:uses
      { :x :inG true . },
      { :i :inG true . },
      { :i :inverseOf :x . }.

  { (:j :e) :mul :j . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 89 ];
    pe:binding [ pe:var "a"; pe:value :j ];
    pe:uses { :j :inG true . }.

  { :i log:notEqualTo :j . }
    pe:by [ pe:builtin log:notEqualTo ].
}.

{ :result :sameInverse (:x :j :i) . } pe:why {
  { :result :sameInverse (:x :j :i) . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 167 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :j ],
      [ pe:var "z"; pe:value :i ];
    pe:uses
      { (:x :j :i) :sameInverse true . },
      { :j log:notEqualTo :i . }.

  { (:x :j :i) :sameInverse true . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 138 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :j ],
      [ pe:var "z"; pe:value :i ];
    pe:uses
      { :j :inverseOf :x . },
      { :i :inverseOf :x . },
      { (:j :i) :sameTerm true . }.

  { :j :inverseOf :x . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 159 ].

  { :i :inverseOf :x . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 158 ].

  { (:j :i) :sameTerm true . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 54 ];
    pe:binding
      [ pe:var "a"; pe:value :i ],
      [ pe:var "ab"; pe:value :e ],
      [ pe:var "b"; pe:value :x ],
      [ pe:var "bc"; pe:value :e ],
      [ pe:var "c"; pe:value :j ],
      [ pe:var "left"; pe:value :j ],
      [ pe:var "right"; pe:value :i ];
    pe:uses
      { (:i :x) :mul :e . },
      { (:e :j) :mul :j . },
      { (:x :j) :mul :e . },
      { (:i :e) :mul :i . }.

  { (:i :x) :mul :e . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 102 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :i ];
    pe:uses
      { :x :inG true . },
      { :i :inG true . },
      { :i :inverseOf :x . }.

  { :x :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 153 ].

  { :i :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 154 ].

  { (:e :j) :mul :j . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 78 ];
    pe:binding [ pe:var "a"; pe:value :j ];
    pe:uses { :j :inG true . }.

  { :j :inG true . }
    pe:by [ pe:fact "group-inverse-uniqueness.n3"; pe:line 155 ].

  { (:x :j) :mul :e . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 102 ];
    pe:binding
      [ pe:var "x"; pe:value :x ],
      [ pe:var "y"; pe:value :j ];
    pe:uses
      { :x :inG true . },
      { :j :inG true . },
      { :j :inverseOf :x . }.

  { (:i :e) :mul :i . }
    pe:by [ pe:rule "group-inverse-uniqueness.n3"; pe:line 89 ];
    pe:binding [ pe:var "a"; pe:value :i ];
    pe:uses { :i :inG true . }.

  { :j log:notEqualTo :i . }
    pe:by [ pe:builtin log:notEqualTo ].
}.
