@prefix : <urn:eyeling-meta#> .
@prefix ex: <urn:demo#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:run :closure {
    ex:Socrates a ex:Human .
    ex:Human rdfs:subClassOf ex:Mortal .
    {
        ?S a ?A .
        ?A rdfs:subClassOf ?B .
    } => {
        ?S a ?B .
    } .
    {
        ?x a ex:Human .
    } log:query {
        ?x a ex:Mortal .
    } .
    {
        ?x a ex:Human .
    } => {
        ex:run :answer {
            ?x a ex:Mortal .
        } .
    } .
    ex:Socrates a ex:Mortal .
    ex:run :answer {
        ex:Socrates a ex:Mortal .
    } .
} .
ex:run :derived {
    {
        ?x a ex:Human .
    } log:query {
        ?x a ex:Mortal .
    } .
} .
ex:run :derived {
    {
        ?x a ex:Human .
    } => {
        ex:run :answer {
            ?x a ex:Mortal .
        } .
    } .
} .
ex:run :derived {
    ex:Socrates a ex:Mortal .
} .
ex:run :answer {
    ex:Socrates a ex:Mortal .
} .
