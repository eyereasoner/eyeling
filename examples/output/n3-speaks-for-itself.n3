    id:bob foaf:name "Bob" .
} :believedFromDoc <https://bob.example/profile.n3> .
:report :believes {
    id:bob foaf:knows id:carol .
} .
{
    id:bob foaf:knows id:carol .
} :believedFromDoc <https://bob.example/profile.n3> .
:report :believes {
    id:carol foaf:name "Carol" .
} .
