    id:carol foaf:name "Carol" .
} :believedFromDoc <https://carol.example/profile.n3> .
:report :believes {
    id:carol foaf:knows id:dave .
} .
{
    id:carol foaf:knows id:dave .
} :believedFromDoc <https://carol.example/profile.n3> .
