ex:realizedPath ex:realizes ex:s4 .
ex:historyBeta ex:incompatibleWith ex:rec2 .
ex:historyBeta ex:incompatibleWith ex:rec3 .
ex:historyGamma ex:incompatibleWith ex:rec3 .
