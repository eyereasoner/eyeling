@prefix ex: <https://example.org/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

_:sk_6 a ex:Person .
_:sk_6 ex:hasSupervisor [
  a ex:Person ;
  ex:role "Supervisor" ;
  ex:supervises _:sk_6
] .
_:sk_6 ex:role "AutoManager" .
ex:Alice a ex:Adult .
ex:Alice a ex:Person .
ex:Alice ex:age "29"^^xsd:integer .
ex:Alice ex:ancestor ex:Bob .
ex:Alice ex:ancestor ex:Carol .
ex:Alice ex:canRead ex:Proj1 .
ex:Alice ex:canRead ex:Proj2 .
ex:Alice ex:memberOf ex:OrgX .
ex:Alice ex:memberOf ex:TeamA .
ex:Alice ex:parent ex:Bob .
ex:Alice ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj1
] .
ex:Alice ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj2
] .
ex:Bob a ex:Adult .
ex:Bob a ex:Person .
ex:Bob ex:age "54"^^xsd:integer .
ex:Bob ex:ancestor ex:Carol .
ex:Bob ex:canRead ex:Proj1 .
ex:Bob ex:canRead ex:Proj2 .
ex:Bob ex:hasSupervisor [
  a ex:Person ;
  ex:role "Supervisor" ;
  ex:supervises ex:Bob
] .
ex:Bob ex:memberOf ex:OrgX .
ex:Bob ex:memberOf ex:TeamA .
ex:Bob ex:parent ex:Carol .
ex:Bob ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj1
] .
ex:Bob ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj2
] .
ex:Carol a ex:Adult .
ex:Carol a ex:Person .
ex:Carol ex:age "78"^^xsd:integer .
ex:Carol ex:canRead ex:Proj1 .
ex:Carol ex:canRead ex:Proj2 .
ex:Carol ex:memberOf ex:OrgX .
ex:Carol ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj1
] .
ex:Carol ex:reason [
  a ex:Reason ;
  ex:because "memberOf(org) & ownedBy(org)" ;
  ex:for ex:Proj2
] .
ex:OrgX a ex:Org .
ex:Proj1 a ex:Project .
ex:Proj1 ex:hasManager ex:Bob .
ex:Proj1 ex:ownedBy ex:OrgX .
ex:Proj2 a ex:Project .
ex:Proj2 ex:hasManager _:sk_6 .
ex:Proj2 ex:needsManager true .
ex:Proj2 ex:ownedBy ex:OrgX .
ex:TeamA a ex:Team .
ex:TeamA ex:partOf ex:OrgX .
