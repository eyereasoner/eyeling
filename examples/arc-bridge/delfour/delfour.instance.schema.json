{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schema/delfour.instance.schema.json",
  "title": "ARC Bridge Flandor instance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "caseName",
    "retailer",
    "question",
    "timestamps",
    "evaluationContext",
    "thresholds",
    "householdProfile",
    "catalog",
    "scan",
    "insightPolicy",
    "integrity"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "caseName": {
      "type": "string",
      "minLength": 1
    },
    "retailer": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdAt",
        "expiresAt",
        "authorizedAt",
        "dutyPerformedAt"
      ],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "authorizedAt": {
          "type": "string",
          "format": "date-time"
        },
        "dutyPerformedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evaluationContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeDevice",
        "scopeEvent",
        "purpose",
        "prohibitedReusePurpose",
        "requestAction"
      ],
      "properties": {
        "scopeDevice": {
          "type": "string",
          "minLength": 1
        },
        "scopeEvent": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "prohibitedReusePurpose": {
          "type": "string",
          "minLength": 1
        },
        "requestAction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sugarPerServingGAtLeast"
      ],
      "properties": {
        "sugarPerServingGAtLeast": {
          "type": "number"
        }
      }
    },
    "householdProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "catalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "sugarTenths",
          "sugarPerServing"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "sugarTenths": {
            "type": "integer",
            "minimum": 0
          },
          "sugarPerServing": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "scan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scannedProductId"
      ],
      "properties": {
        "scannedProductId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "insightPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "metric",
        "type",
        "suggestionPolicy",
        "policyType",
        "policyProfile"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "suggestionPolicy": {
          "type": "string",
          "minLength": 1
        },
        "policyType": {
          "type": "string",
          "minLength": 1
        },
        "policyProfile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hashAlgorithm",
        "macAlgorithm",
        "secret",
        "verificationMode"
      ],
      "properties": {
        "hashAlgorithm": {
          "type": "string",
          "const": "SHA-256"
        },
        "macAlgorithm": {
          "type": "string",
          "const": "HMAC-SHA-256"
        },
        "secret": {
          "type": "string",
          "minLength": 1
        },
        "verificationMode": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
