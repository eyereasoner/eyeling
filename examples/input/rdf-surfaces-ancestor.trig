VERSION "1.2-surfaces"
# eyeling-options: --rdf-surfaces
@prefix ex: <http://example.org/> .

ex:ann ex:parent ex:bob .
ex:bob ex:parent ex:cat .

%not[ _:x _:y
_:x ex:parent _:y .
%not[
_:x ex:ancestor _:y .
%]
%]

%not[ _:x _:y _:z
_:x ex:parent _:y .
_:y ex:ancestor _:z .
%not[
_:x ex:ancestor _:z .
%]
%]
