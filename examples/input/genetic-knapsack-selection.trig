# Formal Eyeling input evidence in RDF 1.2 TriG.
# The generated runner reads this TriG evidence directly.

:Run :capacity 50 .
:Run :startGenome "000000000000" .
:Run :maxGenerations 64 .
:FinalLocal :genome "101000000101" .
:FinalLocal :selectedItems "item01, item03, item10, item12" .
:FinalLocal :weight 50 .
:FinalLocal :value 101 .
:FinalLocal :fitness 999899 .
:FinalLocal :generationsEvaluated 5 .
:ExhaustiveOptimum :genome "001000011111" .
:ExhaustiveOptimum :value 104 .
:NeighborSummary :oneBitNeighborsEvaluated 12 .
:NeighborSummary :bestNeighborValue 101 .
:NeighborSummary :capacityRespected true .

in:metadata {
  in:run a see:InputDataset .
  in:run see:name "genetic_knapsack_selection" .
  in:run see:title "Genetic Knapsack Selection" .
