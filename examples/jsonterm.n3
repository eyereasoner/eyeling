# =================================================
# jsonterm example
#
# Mapping used:
# - JSON objects become anonymous node structures.
# - JSON arrays become N3 lists.
# - JSON null becomes a normal symbol here, j:null.
# =================================================

@prefix ex: <https://example.org/#> .
@prefix j: <https://example.org/json#> .

[
  j:user "alice";
  j:roles ("admin" j:null)
]
("likes" 1)
[
  j:city "Paris";
  j:coords (2.35 48.85)
] .

{
  [
    j:user ?U;
    j:roles ("admin" j:null)
  ]
  ("likes" 1)
  [
    j:city "Paris";
    j:coords (2.35 48.85)
  ] .
}
=>
{
  ex:test ex:is true .
} .
