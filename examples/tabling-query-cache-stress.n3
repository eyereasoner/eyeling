# ===========================================================================
# Tabling-friendly cache stress test
#
# Why this stresses the minimal tabling patch:
#   - The backward goal { :n0 :path ?x. } is expensive: it computes the whole
#     transitive closure of a long chain by backward recursion.
#   - The exact same top-level query premise is repeated many times via
#     log:query directives with different constant conclusions.
#   - During log:query collection the fact set is stable, so completed-answer
#     memoization can be reused across all repeated queries.
#
# Expected effect:
#   - without the patch: each log:query recomputes all reachable ?x answers
#   - with the patch: the first query computes them, later identical queries
#     reuse the cached completed answer set
#
# Note:
#   ?x is intentionally not used in the query conclusions.
#   That keeps the output tiny while still forcing the expensive proof.
# ===========================================================================

@prefix :    <http://example.org/tabling-stress#>.
@prefix log: <http://www.w3.org/2000/10/swap/log#>.

# Backward transitive closure
{ ?x :path ?y. } <= { ?x :edge ?y. }.
{ ?x :path ?z. } <= { ?x :edge ?y. ?y :path ?z. }.

# A long linear chain
:n0 :edge :n1.
:n1 :edge :n2.
:n2 :edge :n3.
:n3 :edge :n4.
:n4 :edge :n5.
:n5 :edge :n6.
:n6 :edge :n7.
:n7 :edge :n8.
:n8 :edge :n9.
:n9 :edge :n10.
:n10 :edge :n11.
