# Adapted from eyeling/examples/witch.n3.
# Monty Python-style rule chain.
@prefix : <https://eyereasoner.github.io/eye/reasoning/witch#>.

:elsie a :WOMAN, :BURNS.
:robin a :MAN, :BURNS.
:agnes a :WOMAN.

{ ?x a :BURNS. ?x a :WOMAN. } => { ?x a :WITCH. }.
{ ?x a :WITCH. } => { ?x a :WEIGHS_THE_SAME_AS_A_DUCK. }.
