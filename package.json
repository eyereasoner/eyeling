{
  "name": "eyeling",
  "version": "2.35.3",
  "description": "A minimal Notation3 (N3) reasoner in JavaScript.",
  "main": "./index.js",
  "keywords": [
    "N3",
    "reasoner"
  ],
  "license": "MIT",
  "author": "Jos De Roo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyereasoner/eyeling.git"
  },
  "homepage": "https://github.com/eyereasoner/eyeling#readme",
  "bin": {
    "eyeling": "./bin/eyeling.cjs"
  },
  "types": "./index.d.ts",
  "files": [
    "LICENSE.md",
    "README.md",
    "eyeling-builtins.ttl",
    "eyeling.js",
    "index.js",
    "index.d.ts",
    "browser.d.ts",
    "bin",
    "dist",
    "docs",
    "lib",
    "test",
    "tools",
    "examples",
    "spec",
    "notes"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "node tools/bundle.js",
    "test:packlist": "node test/packlist.test.js",
    "test:api": "node test/api.test.js",
    "test:builtins": "node test/builtins.test.js",
    "test:store": "node test/store.test.js",
    "test:examples": "node test/examples.test.js",
    "test:examples:proof": "node test/examples.test.js --proof-only",
    "test:stream-messages": "node test/stream_messages.test.js",
    "test:manifest": "node test/manifest.test.js",
    "test:rdf12": "node test/rdf12.test.js",
    "test:rdf12:ntriples": "node test/rdf12.test.js ntriples",
    "test:rdf12:nquads": "node test/rdf12.test.js nquads",
    "test:rdf12:turtle": "node test/rdf12.test.js turtle",
    "test:rdf12:trig": "node test/rdf12.test.js trig",
    "test:playground": "node test/playground.test.js",
    "test:package": "node test/package.test.js",
    "test": "node test/run.js",
    "preversion": "npm test",
    "postversion": "git push origin HEAD --follow-tags"
  },
  "dependencies": {
    "@rdfjs/types": "^2.0.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "rdf-test-suite": "^2.1.4"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./dist/browser/index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./browser": {
      "types": "./browser.d.ts",
      "default": "./dist/browser/index.mjs"
    },
    "./eyeling.js": "./eyeling.js",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "browser": [
        "browser.d.ts"
      ]
    }
  },
  "optionalDependencies": {
    "classic-level": "^3.0.0",
    "browser-level": "^3.0.0"
  }
}
